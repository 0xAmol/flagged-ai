{
  "manifest_version": 3,
  "name": "Artifake \u2014 AI content scanner",
  "version": "0.5.2",
  "description": "Flag AI-generated content where you find it, and see what the crowd has already flagged.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://flagged-api.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "flag.ai \u2014 is this AI?"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "db.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}